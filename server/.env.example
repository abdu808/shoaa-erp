# The system ships READY with these defaults (baked into the Dockerfile),
# so deployment needs ZERO env config. Copy to server/.env only for local dev
# or to override in production.
#
# TEST login (default): abdu808@gmail.com / 123456
# After first login: change the password from the Settings page.
# In production: also set a strong JWT_SECRET in your host/Coolify env.

DATABASE_URL="file:../data/invoicing.sqlite"
JWT_SECRET="shoaa-default-secret-change-me-in-coolify-env"
PORT=8080
ADMIN_EMAIL="abdu808@gmail.com"
ADMIN_PASSWORD="123456"
ADMIN_NAME="المدير العام"
